# Required
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# 32-byte key as 64 hex chars, or base64, or passphrase ≥16 chars (dev only)
SMART_HAWK_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Storage
DATABASE_URL=sqlite:data/smart-hawk.db?mode=rwc

# Public links (About screen)
ABOUT_LANDING_URL=https://hawk.aryagorjipour.com
ABOUT_GITHUB_URL=https://github.com/Aryagorjipour/hawk

# Optional email (schedule delivery)
# Prefer Resend; SMTP is used as fallback if Resend fails or is unset.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Smart Hawk <bot@yourdomain.com>
# EMAIL_FROM=Smart Hawk <bot@yourdomain.com>
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# SMTP_FROM=Smart Hawk <bot@yourdomain.com>

# Optional headless browser fallback
# CHROMIUM_PATH=/usr/bin/chromium

# Optional operator notify chat
# OPERATOR_NOTIFY_CHAT_ID=123456789

# Runtime
RUST_LOG=info,smart_hawk=debug
WORKER_POOL_SIZE=4
SCHEDULE_POLL_SECS=30
